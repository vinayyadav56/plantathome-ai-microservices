# ─── Anthropic Claude API ───────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ─── Service Auth (inter-service API key) ───────────────
SERVICE_API_KEY=your_service_api_key_here
JWT_SECRET=your_jwt_secret_here

# ─── Redis ──────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Elasticsearch ──────────────────────────────────────
ELASTICSEARCH_URL=http://localhost:9200

# ─── RabbitMQ ───────────────────────────────────────────
RABBITMQ_URL=amqp://plantathome:plantathome_secret@localhost:5672/
RABBITMQ_USER=plantathome
RABBITMQ_PASS=plantathome_secret

# ─── AWS S3 ─────────────────────────────────────────────
AWS_ACCESS_KEY_ID=your_aws_key
AWS_SECRET_ACCESS_KEY=your_aws_secret
AWS_BUCKET_NAME=plantathome-images
AWS_REGION=ap-south-1

# ─── Email (SMTP) ───────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM=noreply@plantathome.in

# ─── WhatsApp (Meta Business API) ───────────────────────
WHATSAPP_API_URL=https://graph.facebook.com/v18.0
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_ACCESS_TOKEN=your_whatsapp_token

# ─── SMS (Twilio) ────────────────────────────────────────
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_token
TWILIO_SMS_FROM=+1xxxxxxxxxx

# ─── Firebase Push Notifications ─────────────────────────
FIREBASE_CREDENTIALS_JSON={"type":"service_account",...}

# ─── Plant.id API (Plant Doctor) ────────────────────────
PLANT_ID_API_KEY=your_plant_id_api_key

# ─── Service URLs (for Laravel API Gateway) ─────────────
RECOMMENDATION_SERVICE_URL=http://localhost:8001
CHATBOT_SERVICE_URL=http://localhost:8002
PLANT_DOCTOR_SERVICE_URL=http://localhost:8003
SEO_SERVICE_URL=http://localhost:8004
SEMANTIC_SEARCH_SERVICE_URL=http://localhost:8005
NOTIFICATION_SERVICE_URL=http://localhost:8006
MEDIA_SERVICE_URL=http://localhost:8007
ANALYTICS_SERVICE_URL=http://localhost:8008

# ─── Environment ─────────────────────────────────────────
ENVIRONMENT=development
